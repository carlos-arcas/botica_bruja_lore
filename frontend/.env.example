NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Contrato frontend:
# - Local/dev: si falta NEXT_PUBLIC_API_BASE_URL, el frontend usa fallback http://127.0.0.1:8000.
# - Producción/CI/Railway: NEXT_PUBLIC_API_BASE_URL es obligatoria, debe ser URL absoluta HTTPS
#   y no puede usar localhost/127.0.0.1/0.0.0.0.
