# Backend (Railway UI -> servicio Django)
SECRET_KEY=REEMPLAZAR_CON_SECRETO_LARGO_Y_UNICO
DEBUG=false
ALLOWED_HOSTS=TU-BACKEND.up.railway.app
CSRF_TRUSTED_ORIGINS=https://TU-BACKEND.up.railway.app
# Opcional: nivel de logging backend (DEBUG, INFO, WARNING, ERROR).
# Default seguro/recomendado: INFO
LOG_LEVEL=INFO

# OBLIGATORIA en Railway para el servicio backend: no omitir.
# Si falta, el backend falla por diseño para evitar fallback incorrecto en producción.
# En el despliegue actual el alias esperado es `Postgres`.
DATABASE_URL=${{Postgres.DATABASE_URL}}
PUBLIC_SITE_URL=https://TU-FRONTEND.up.railway.app
DEFAULT_FROM_EMAIL=operaciones@TU-DOMINIO.com
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYMENT_SUCCESS_URL=https://TU-FRONTEND.up.railway.app/pedido/{CHECKOUT_SESSION_ID}
PAYMENT_CANCEL_URL=https://TU-FRONTEND.up.railway.app/checkout?estado_pago=cancelado
GOOGLE_CLIENT_ID=
CREAR_ADMIN_PROVISIONAL=false
ADMIN_USUARIO_PROVISIONAL=
ADMIN_PASSWORD_PROVISIONAL=
DEBUG_LOG_VIEWER_ENABLED=false
DEBUG_LOG_VIEWER_KEY=

# El repo fuerza `backend.configuracion_django.settings` desde código (manage.py y wsgi.py).
# Aun así, elimina variables legacy en Railway UI para evitar desvíos operativos.
# Variables legacy conflictivas (eliminarlas si existen en Railway UI)
# APP_DEBUG=
# DJANGO_SETTINGS_MODULE=
# WSGI_APPLICATION=

# Frontend (Railway UI -> servicio Next.js)
NEXT_PUBLIC_API_BASE_URL=https://TU-BACKEND.up.railway.app
NEXT_PUBLIC_SITE_URL=https://TU-FRONTEND.up.railway.app
NEXT_PUBLIC_ADMIN_BASE_URL=https://TU-BACKEND.up.railway.app
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Solo backend/frontend server-side: token de verificación de Search Console.
GOOGLE_SITE_VERIFICATION_TOKEN=
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
# Si el frontend necesita mostrar el acceso técnico al visor de logs,
# reutiliza DEBUG_LOG_VIEWER_ENABLED=true también en ese servicio.
