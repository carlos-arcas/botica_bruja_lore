# Backend (Railway Variables)
SECRET_KEY=REEMPLAZAR_CON_SECRETO_LARGO_Y_UNICO
DEBUG=false
ALLOWED_HOSTS=TU-BACKEND.up.railway.app
CSRF_TRUSTED_ORIGINS=https://TU-BACKEND.up.railway.app
# Opcional: nivel de logging backend (DEBUG, INFO, WARNING, ERROR).
# Default seguro/recomendado: INFO
LOG_LEVEL=INFO

# OBLIGATORIA en Railway para el servicio backend: no omitir.
# Si falta, el backend falla por diseño para evitar fallback incorrecto en producción.
# Reemplaza SERVICE_NAME por el nombre real del servicio PostgreSQL en Railway UI.
DATABASE_URL=${{SERVICE_NAME.DATABASE_URL}}

# El repo fuerza `backend.configuracion_django.settings` desde código (manage.py y wsgi.py).
# Aun así, elimina variables legacy en Railway UI para evitar desvíos operativos.
# Variables legacy conflictivas (eliminarlas si existen en Railway UI)
# APP_DEBUG=
# DJANGO_SETTINGS_MODULE=
# WSGI_APPLICATION=

# Frontend (Railway Variables)
NEXT_PUBLIC_API_BASE_URL=https://TU-BACKEND.up.railway.app
# OBLIGATORIA en Railway/CI/producción para frontend.
# Debe ser URL absoluta HTTPS y no puede apuntar a localhost/127.0.0.1/0.0.0.0.
